(startRule compilationUnit M-ID .  FILECONTROLREAD .\n       \n       \n        FILE-CONTROL .\n        SELECT PERSON ASSIGN TO 'person.txt' ORGANIZATION IS LINE SEQUENTIAL .\n       \n        IVISION .\n       \n        PERSON .\n        PERSON-FILE .\n        05 PERSON-ID PIC 9 ( 5 ) .\n        05 NAME PIC A ( 25 ) .\n       \n       \n        WS-PERSON .\n        05 WS-PERSON-ID PIC 9 ( 5 ) .\n        05 WS-NAME PIC A ( 25 ) .\n        WS-EOF PIC A ( 1 ) .)